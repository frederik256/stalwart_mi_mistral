{
  "$schema": "https://raw.githubusercontent.com/frederik256/stalwart_mi_mistral/main/configs/stalwart-config.schema.json",
  "description": "Stalwart Mail Server configuration for Stalwart Migration Tool",
  "version": "1.0",

{
  // Stalwart API configuration for integration tests
  "Stalwart": {
    "ApiUrl": "http://localhost:8080",
    "TimeoutSeconds": 60,
    "MaxRetries": 5,
    "TestMode": true
  },
  
  // Docker configuration
  "Docker": {
    "Image": "stalwartlabs/stalwart:v0.16",
    "ContainerName": "stalwart-test",
    "HostPort": 8080,
    "ContainerPort": 8080,
    "Volumes": {
      "Config": "stalwart-test-etc:/etc/stalwart",
      "Data": "stalwart-test-data:/var/lib/stalwart"
    },
    "Environment": {
      "STALWART_RECOVERY_ADMIN": "admin"
    }
  },
  
  // Test credentials (these are test-only, not production credentials)
  "TestCredentials": {
    "AdminUsername": "admin",
    "MinPasswordLength": 16,
    "PasswordComplexity": {
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigits": true,
      "RequireSpecialChars": true
    }
  },
  
  // Test data configuration
  "TestData": {
    "DefaultDomain": "test.example.com",
    "TestAccountPrefix": "testuser",
    "MaxTestAccounts": 10,
    "CleanupOnTeardown": true
  },
  
  // Logging configuration
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "StalwartMigration": "Debug",
      "System.Net.Http": "Warning"
    },
    "CaptureApiRequests": true,
    "SanitizeSensitiveData": true
  },
  
  // Timeout configuration
  "Timeouts": {
    "ContainerStartupSeconds": 120,
    "HealthCheckSeconds": 30,
    "ApiRequestSeconds": 30,
    "TestExecutionSeconds": 300
  }
}
